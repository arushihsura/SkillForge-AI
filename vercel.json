{
  "version": 2,
  "name": "skillforge-ai",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ],
  "env": {
    "SF_MODE": "serverless",
    "PYTHONPATH": "."
  }
}
