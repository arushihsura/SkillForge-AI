# SkillForge AI local environment
PORT=5000
# Update with your MongoDB URI
MONGO_URI=mongodb://localhost:27017/skillforge
JWT_SECRET=supersecretjwtkey

# Mode: 'serverless' is easiest for local demo (no separate ML daemon needed)
SF_MODE=serverless
# Path to the ML engine script
ML_DAEMON_PATH=../ml/skill_gap_model.py

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173
node_env=development
